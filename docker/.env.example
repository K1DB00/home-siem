# =============================================================================
# Home SIEM — Docker environment configuration (EXAMPLE)
# =============================================================================
# Copy this file to `.env` in the same directory and fill in real values
# before running `docker compose up`. `.env` itself is excluded from Git
# (see .gitignore) — only this example file, with placeholders, is tracked.
#
# This phase configures Elasticsearch only. Variables for Kibana and Fleet
# Server will be added to this file in their respective later phases
# (docs/deployment/docker-deployment.md, Section 16), not introduced now.
# =============================================================================

# --- Elastic Stack version ---------------------------------------------------
# Pinned to a specific version, never `latest`, so every deployment uses a
# deliberately chosen, known-compatible release
# (04-docker-architecture.md, Section 16).
STACK_VERSION=9.4.4

# --- Cluster / node identity --------------------------------------------------
ELASTIC_CLUSTER_NAME=home-siem
ELASTIC_NODE_NAME=es01

# --- Container naming ---------------------------------------------------------
ELASTIC_CONTAINER_NAME=home-siem-elasticsearch
SETUP_CONTAINER_NAME=home-siem-setup

# --- Networking / port bindings ------------------------------------------------
# VMnet1 host-only address for this lab, confirmed against the running host
# adapter in 02-network-topology.md, Section 3. Elasticsearch is bound to this
# address only — never 0.0.0.0 — per 04-docker-architecture.md, Section 7.
# If reproducing this lab on a different host, verify this address in
# VMware's Virtual Network Editor before reusing it (02-network-topology.md,
# Section 13).
ELASTIC_VMNET1_HOST_IP=192.168.72.1
ELASTIC_PORT=9200

# --- Resource allocation (docker-deployment.md, Section 8) ---------------------
ELASTIC_JVM_HEAP=2g
ELASTIC_MEM_LIMIT=4g
ELASTIC_MEM_RESERVATION=2g
ELASTIC_CPU_LIMIT=2

# --- Bootstrap credentials -----------------------------------------------------
# Placeholder only. Replace with a strong, unique, generated value in your
# real `.env` file. Never commit the real value, and never reuse it as the
# Fleet Server service token or an Elastic Agent enrollment token once those
# are introduced — each credential in this design is scoped to one role and
# is not interchangeable (06-security-architecture.md, Sections 8 and 11).
ELASTIC_PASSWORD=changeme
